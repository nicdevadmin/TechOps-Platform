# =============================================================================
# TechOps Platform — Environment Configuration
# Copy this file: cp .env.example .env
# IMPORTANT: Never commit .env to git. It is already in .gitignore.
# =============================================================================

# ── CORE ──────────────────────────────────────────────────────────────────────
# Your domain. All services are subdomains of this.
# Local: use localhost or 192.168.x.x (TLS won't work, use docker-compose.local.yml)
# Production: your real domain e.g. example.com
BASE_DOMAIN=techops.example.com

# Timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# ── DATABASE (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_USER=techops
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── CACHE (Redis) ────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ── TRAEFIK ───────────────────────────────────────────────────────────────────
# Email for Let's Encrypt TLS certificates
ACME_EMAIL=admin@example.com

# Basic auth for Traefik dashboard and Prometheus UI
# Generate: htpasswd -nb admin yourpassword | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxxxxxx$$xxxxxxxxxxxxxxxxxxxxxxx

# ── FORGEJO (Git) ────────────────────────────────────────────────────────────
FORGEJO_DISABLE_REGISTRATION=true
FORGEJO_REQUIRE_SIGNIN=true

# ── VIKUNJA (Tasks) ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
VIKUNJA_JWT_SECRET=CHANGE_ME_JWT_SECRET_HERE
VIKUNJA_ENABLE_REGISTRATION=false

# ── BOOKSTACK (Wiki) ─────────────────────────────────────────────────────────
# Generate: php artisan key:generate --show (or use openssl rand -base64 32)
BOOKSTACK_APP_KEY=base64:CHANGE_ME_BOOKSTACK_KEY_HERE

# ── N8N (Automation) ─────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD_HERE
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY_HERE

# ── MEILISEARCH ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
MEILISEARCH_MASTER_KEY=CHANGE_ME_MEILISEARCH_KEY_HERE

# ── GRAFANA (Dashboards) ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD_HERE
# Generate: openssl rand -hex 32
GRAFANA_SECRET_KEY=CHANGE_ME_GRAFANA_SECRET_HERE

# ── EMAIL / SMTP ──────────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true and fill in the fields below to enable email
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=techops@example.com
SMTP_DRIVER=smtp

# ── NOTIFICATIONS ─────────────────────────────────────────────────────────────
# Slack webhook for Watchtower notifications (optional)
SLACK_WEBHOOK_URL=

# ── WATCHTOWER ────────────────────────────────────────────────────────────────
# true = monitor only, don't auto-update (recommended)
# false = automatically pull and restart updated containers
WATCHTOWER_MONITOR_ONLY=true
